<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Window theme for the single Activity (Compose draws over it). The legacy Widget.Shrine.*
         styles that backed the XML/Fragment layouts were removed in plan_8 Phase 5. -->
    <style name="Theme.Shrine" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <!-- System-bar icon appearance is driven from the Compose theme at runtime
             (ShrineApp + WindowInsetsControllerCompat, plan_9 Phase A), not hard-coded here,
             so the icons follow light/dark instead of always rendering dark-on-dark. -->
        <item name="android:textColorPrimary">@color/textColorPrimary</item>
    </style>

</resources>
